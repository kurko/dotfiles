#!/bin/bash

# photos-cull - Make Photomator's cull durable by exporting it to XMP sidecars
#
# WHY THIS EXISTS:
#   Photomator stores the star ratings and rejects you apply in its Files browser
#   ONLY in a local catalog (FilesLibrary.plist inside its Group Container). Those
#   decisions are NOT written next to your photos, NOT in iCloud, and NOT captured
#   by a file-level backup. If that catalog is lost, your cull is gone.
#
#   This tool reads your cull from Photomator's catalog and writes a standard XMP
#   sidecar (basename.xmp) next to each photo: stars as <xmp:Rating>1..5</xmp:Rating>
#   and rejects as <xmp:Rating>-1</xmp:Rating> (the XMP convention for "rejected").
#   Then a normal file backup (e.g. photos-backup) carries your cull to your SSDs,
#   and any XMP-aware app can read it.
#
# IMPORTANT - QUIT PHOTOMATOR FIRST:
#   Photomator writes its catalog live; a snapshot taken while it runs can be
#   inconsistent (we have seen reject counts momentarily read as zero mid-write).
#   This tool refuses to run while Photomator/Pixelmator is open unless you pass
#   --allow-running.
#
# IMPORTANT - ONE-WAY SNAPSHOT, NOT LIVE SYNC:
#   Photomator reads an adjacent sidecar on "Refresh Folder" but never writes
#   ratings back to sidecars. So a sidecar is a point-in-time snapshot of the
#   catalog. Re-run this after further culling. If you "Refresh Folder" with a
#   STALE sidecar present, Photomator overwrites the newer in-app rating with the
#   old sidecar value. Safe routine: cull -> quit Photomator -> run photos-cull.
#
# USAGE:
#   photos-cull [OPTIONS] [PATH ...]
#
#   PATH   One or more folders to limit the export to (absolute, or relative to
#          the Photography library). Default: the whole library.
#
# OPTIONS:
#   -n, --dry-run     Show what would be written without writing anything
#   -v, --verbose     List every catalog entry considered
#   --allow-running   Export even while Photomator is open (not recommended)
#   -h, --help        Show this help
#
# SAFETY:
#   - Only ever writes *.xmp sidecars; never touches your RAW/JPEG originals.
#   - Never overwrites a sidecar it did not create (so Photomator/Pixelmator edit
#     sidecars are preserved). It marks its own sidecars and only updates those.

set -euo pipefail

# =============================================================================
# Configuration
# =============================================================================

SOURCE_DIR="$HOME/Pictures/Photography"
LOG_DIR="$HOME/.local/log"
LOG_FILE="$LOG_DIR/photos-cull.log"
PHOTOMATOR_PLIST="$HOME/Library/Group Containers/4R6749AYRE.com.pixelmator/Library/Files Library/FilesLibrary.plist"

# Marker that identifies a sidecar this tool wrote (so re-runs can update it
# while never clobbering sidecars created by Photomator or other apps).
SIDECAR_MARKER="generated by photos-cull"

# =============================================================================
# Colors
# =============================================================================

RED='\033[91m'
YELLOW='\033[93m'
GREEN='\033[92m'
BOLD='\033[1m'
NC='\033[0m'

# =============================================================================
# Globals
# =============================================================================

VERSION="2.2"
DRY_RUN=false
VERBOSE=false
ALLOW_RUNNING=false
ERRORS=false
TARGETS=()
TEMP_DIR=""

COUNT_WRITTEN=0
COUNT_UPDATED=0
COUNT_UPTODATE=0
COUNT_REJECTS=0
COUNT_SKIPPED_FOREIGN=0
COUNT_MISSING=0

# =============================================================================
# Helpers
# =============================================================================

log() {
    local msg="$1"
    echo -e "$msg"
    echo -e "$msg" | sed 's/\x1b\[[0-9;]*m//g' >> "$LOG_FILE"
}

log_verbose() {
    if [[ "$VERBOSE" == true ]]; then
        log "$1"
    fi
}

cleanup() {
    if [[ -n "$TEMP_DIR" && -d "$TEMP_DIR" ]]; then
        rm -rf "$TEMP_DIR"
    fi
}
trap cleanup EXIT

show_help() {
    cat << EOF
photos-cull v${VERSION}

Exports the cull you made in Photomator (star ratings AND rejects) into standard
XMP sidecars (basename.xmp) next to each photo, so it is durable, portable, and
picked up by a normal file backup. Stars become <xmp:Rating>1..5</xmp:Rating>;
rejects become <xmp:Rating>-1</xmp:Rating>. Never touches your originals; never
overwrites a sidecar it didn't create.

USAGE:
    photos-cull [OPTIONS] [PATH ...]

    PATH   Folders to limit the export to (absolute, or relative to the library).
           Default: the whole library.

OPTIONS:
    -n, --dry-run     Show what would be written without writing
    -v, --verbose     List every catalog entry considered
    --allow-running   Export even while Photomator is open (not recommended)
    -h, --help        Show this help

WORKFLOW (sidecars are a one-way snapshot, so order matters):
    1. Cull in Photomator (rate / reject).
    2. Quit Photomator. Its catalog is written live, so this tool refuses to run
       while it is open (a mid-write snapshot can be incomplete).
    3. Run photos-cull. Each run:
         - writes a new sidecar for a photo that has none;
         - updates a sidecar it previously wrote, if the rating changed;
         - skips (preserves) any sidecar it did NOT create (e.g. Pixelmator
           edit sidecars).
    4. Only then re-open or "Refresh Folder" in Photomator.

    Why the order: Photomator reads an adjacent sidecar but never writes ratings
    back to one. If you change a rating in Photomator and let it re-read the
    folder BEFORE you re-run photos-cull, the older sidecar value overrides your
    change. Re-running photos-cull first keeps the sidecar in sync.

EXAMPLES:
    photos-cull -n                                   # Dry run, whole library
    photos-cull "2026/2026-05 Camino de Santiago"    # Export just that trip
EOF
}

rel_display() {
    printf '%s' "${1#"$SOURCE_DIR"/}"
}

# Extract "value<TAB>absolute_path" pairs from one dict of the catalog.
# For flaggedAssets, only rejects (value -1) are emitted; picks (+1) are skipped
# because there is no standard xmp:Rating for a "pick".
_parse_section() {
    local section="$1"
    plutil -convert xml1 -o - "$PHOTOMATOR_PLIST" 2>/dev/null | awk -v section="$section" '
        $0 ~ ("<key>" section "</key>") { f=1; next }
        f==1 && /<dict>/   { f=2; next }
        f==2 && /<\/dict>/ { f=0; next }
        f==2 && /<key>/    { line=$0; sub(/.*<key>/,"",line);     sub(/<\/key>.*/,"",line);     k=line; next }
        f==2 && /<integer>/{ line=$0; sub(/.*<integer>/,"",line); sub(/<\/integer>.*/,"",line);
                             if (section != "flaggedAssets" || line == "-1") print line "\t" k; next }
    '
}

# Emit the full cull. Rejects first, so a reject wins over any stale star rating
# on the same file (the loop keeps the first decision seen per sidecar).
parse_cull_decisions() {
    _parse_section flaggedAssets
    _parse_section ratedAssets
}

# Decode the handful of XML entities that can appear in a path.
decode_entities() {
    local s="$1"
    s="${s//&amp;/&}"; s="${s//&lt;/<}"; s="${s//&gt;/>}"
    s="${s//&quot;/\"}"; s="${s//&apos;/\'}"
    printf '%s' "$s"
}

is_our_sidecar() {
    LC_ALL=C grep -aq "$SIDECAR_MARKER" "$1" 2>/dev/null
}

current_sidecar_rating() {
    LC_ALL=C grep -a -o -m1 -E '<xmp:Rating>-?[0-9]+' "$1" 2>/dev/null | sed 's/.*>//' || true
}

write_sidecar() {
    local sidecar="$1" rating="$2"
    cat > "$sidecar" << EOF
<x:xmpmeta xmlns:x="adobe:ns:meta/" x:xmptk="XMP Core 6.0.0">
   <!-- ${SIDECAR_MARKER}: cull exported from Photomator; safe to regenerate -->
   <rdf:RDF xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#">
      <rdf:Description rdf:about=""
            xmlns:xmp="http://ns.adobe.com/xap/1.0/">
         <xmp:Rating>${rating}</xmp:Rating>
      </rdf:Description>
   </rdf:RDF>
</x:xmpmeta>
EOF
}

# Human-readable rating for log lines: stars for 1-5, REJECT for -1.
rating_label() {
    if [[ "$1" == "-1" ]]; then printf 'REJECT'; else printf '%s*' "$1"; fi
}

# True if Photomator or Pixelmator Pro is running (they share the catalog and
# write it live, so a snapshot taken while they run can be inconsistent).
photomator_running() {
    pgrep -i 'photomator' >/dev/null 2>&1 || pgrep -i 'pixelmator' >/dev/null 2>&1
}

# =============================================================================
# Argument parsing
# =============================================================================

parse_args() {
    while [[ $# -gt 0 ]]; do
        case "$1" in
            -n|--dry-run)    DRY_RUN=true; shift ;;
            -v|--verbose)    VERBOSE=true; shift ;;
            --allow-running) ALLOW_RUNNING=true; shift ;;
            -h|--help)       show_help; exit 0 ;;
            --)              shift; while [[ $# -gt 0 ]]; do TARGETS+=("$1"); shift; done ;;
            -*)
                echo "Unknown option: $1"
                echo "Use --help for usage information"
                exit 1
                ;;
            *) TARGETS+=("$1"); shift ;;
        esac
    done
}

resolve_target() {
    local t="$1"
    if [[ -d "$t" ]]; then
        printf '%s' "$t"
    elif [[ -d "$SOURCE_DIR/$t" ]]; then
        printf '%s' "$SOURCE_DIR/$t"
    else
        return 1
    fi
}

# =============================================================================
# Export
# =============================================================================

export_ratings() {
    local filter="$1"
    local seen="$TEMP_DIR/seen.txt"
    : > "$seen"

    local prefix=""
    if [[ "$DRY_RUN" == true ]]; then
        prefix="[DRY RUN] "
    fi
    log ""
    log "${prefix}Exporting cull under: ${BOLD}$(rel_display "$filter")${NC}"

    local rating path dir base name sidecar label cur
    while IFS=$'\t' read -r rating path; do
        if [[ -z "$path" ]]; then continue; fi
        path=$(decode_entities "$path")

        # Only photos under the requested folder.
        if [[ "$path" != "$filter"/* ]]; then continue; fi

        if [[ ! -f "$path" ]]; then
            COUNT_MISSING=$((COUNT_MISSING + 1))
            log_verbose "  ${YELLOW}missing on disk${NC}: $(rel_display "$path") ($(rating_label "$rating"))"
            continue
        fi

        dir=$(dirname "$path")
        base=$(basename "$path")
        name="${base%.*}"
        sidecar="$dir/$name.xmp"

        # A RAW+JPEG pair shares one basename.xmp; keep the first decision seen
        # (rejects are emitted first, so a reject wins over a stale star rating).
        if grep -qxF "$sidecar" "$seen" 2>/dev/null; then continue; fi
        echo "$sidecar" >> "$seen"

        label="$(rel_display "$dir")/$name -> $(rating_label "$rating")"

        if [[ -e "$sidecar" ]]; then
            if is_our_sidecar "$sidecar"; then
                cur=$(current_sidecar_rating "$sidecar")
                if [[ "$cur" == "$rating" ]]; then
                    COUNT_UPTODATE=$((COUNT_UPTODATE + 1))
                    log_verbose "  up to date: $label"
                    continue
                fi
                if [[ "$DRY_RUN" == true ]]; then
                    log "  ${YELLOW}Would update${NC}: $label (was ${cur:-?})"
                elif write_sidecar "$sidecar" "$rating"; then
                    log "  ${YELLOW}Update${NC}: $label (was ${cur:-?})"
                else
                    log "  ${RED}Failed${NC}: $label"; ERRORS=true; continue
                fi
                COUNT_UPDATED=$((COUNT_UPDATED + 1))
                if [[ "$rating" == "-1" ]]; then COUNT_REJECTS=$((COUNT_REJECTS + 1)); fi
            else
                COUNT_SKIPPED_FOREIGN=$((COUNT_SKIPPED_FOREIGN + 1))
                log_verbose "  skip (foreign sidecar, preserved): $(rel_display "$dir")/$name.xmp"
            fi
        else
            if [[ "$DRY_RUN" == true ]]; then
                log "  ${GREEN}Would write${NC}: $label"
            elif write_sidecar "$sidecar" "$rating"; then
                log "  ${GREEN}Write${NC}: $label"
            else
                log "  ${RED}Failed${NC}: $label"; ERRORS=true; continue
            fi
            COUNT_WRITTEN=$((COUNT_WRITTEN + 1))
            if [[ "$rating" == "-1" ]]; then COUNT_REJECTS=$((COUNT_REJECTS + 1)); fi
        fi
    done < <(parse_cull_decisions)
}

# =============================================================================
# Main
# =============================================================================

main() {
    parse_args "$@"

    mkdir -p "$LOG_DIR"
    {
        echo ""
        echo "========================================"
        echo "$(date): photos-cull started"
    } >> "$LOG_FILE"

    log ""
    log "${BOLD}photos-cull v${VERSION}${NC}"
    log "================"
    if [[ "$DRY_RUN" == true ]]; then
        log "${YELLOW}[DRY RUN MODE]${NC}"
    fi

    if [[ ! -d "$SOURCE_DIR" ]]; then
        log "${RED}Error: library not found: $SOURCE_DIR${NC}"
        exit 1
    fi
    if [[ ! -f "$PHOTOMATOR_PLIST" ]]; then
        log "${RED}Error: Photomator catalog not found:${NC}"
        log "  $PHOTOMATOR_PLIST"
        exit 1
    fi

    # Convert the catalog to XML once, failing loud if it can't be parsed, so a
    # parse failure can never masquerade as a successful empty backup (the later
    # read happens in a process substitution whose failure would be swallowed).
    local plist_xml
    if ! plist_xml=$(plutil -convert xml1 -o - "$PHOTOMATOR_PLIST" 2>/dev/null); then
        log "${RED}Error: Photomator catalog could not be parsed (corrupt or unexpected format).${NC}"
        log "  Refusing to run. $PHOTOMATOR_PLIST"
        exit 1
    fi
    # Guard against a future Photomator schema change silently yielding 0 ratings.
    # (here-string, not a pipe, so grep -q can't SIGPIPE plutil under pipefail)
    if ! LC_ALL=C grep -q '<key>ratedAssets</key>' <<< "$plist_xml"; then
        log "${RED}Error: catalog format not recognized (no 'ratedAssets' key).${NC}"
        log "  Photomator may have changed how it stores ratings; this tool needs"
        log "  updating before it can be trusted. Refusing to run."
        exit 1
    fi

    # A live catalog can be read mid-write (we have seen reject counts swing to
    # zero while Photomator was rewriting it). Refuse a real run in that case so
    # we never write partial sidecars that would later overwrite the real cull.
    if photomator_running; then
        if [[ "$DRY_RUN" == true ]]; then
            log "${YELLOW}Note: Photomator/Pixelmator is running - the catalog may be mid-write,${NC}"
            log "${YELLOW}      so the counts below can be inconsistent. (Dry run; nothing written.)${NC}"
        elif [[ "$ALLOW_RUNNING" == true ]]; then
            log "${YELLOW}Warning: writing while Photomator/Pixelmator is open (--allow-running).${NC}"
        else
            log "${RED}Refusing to run: Photomator/Pixelmator is running.${NC}"
            log "  Its catalog is written live; a snapshot now could be incomplete and"
            log "  would overwrite your sidecars with partial data. Quit it and re-run,"
            log "  or pass --allow-running to override."
            exit 1
        fi
    fi

    # Resolve target folders (default: whole library).
    local dirs=() t resolved
    if [[ ${#TARGETS[@]} -eq 0 ]]; then
        dirs=("$SOURCE_DIR")
    else
        for t in "${TARGETS[@]}"; do
            if resolved=$(resolve_target "$t"); then
                dirs+=("$resolved")
            else
                log "${RED}Error: folder not found: $t${NC}"
                exit 1
            fi
        done
    fi

    TEMP_DIR=$(mktemp -d)

    for t in "${dirs[@]}"; do
        export_ratings "$t"
    done

    # Summary
    local suffix=""
    if [[ "$DRY_RUN" == true ]]; then
        suffix=" (dry run)"
    fi
    log ""
    log "${BOLD}Summary${suffix}:${NC}"
    log "  Sidecars written (new): $COUNT_WRITTEN"
    log "  Sidecars updated (changed): $COUNT_UPDATED"
    log "  Already up to date: $COUNT_UPTODATE"
    log "  (of written/updated, rejects as -1: $COUNT_REJECTS)"
    log "  Foreign sidecars preserved (skipped): $COUNT_SKIPPED_FOREIGN"
    log "  In catalog but missing on disk: $COUNT_MISSING"
    if [[ "$ERRORS" == true ]]; then
        log "  ${RED}! Some sidecars failed to write - check output above${NC}"
    fi
    log ""
    log "Log written to: $LOG_FILE"
    echo "$(date): photos-cull completed" >> "$LOG_FILE"

    if [[ "$ERRORS" == true ]]; then
        exit 1
    fi
}

main "$@"
